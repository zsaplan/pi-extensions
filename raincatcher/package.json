{
  "name": "@zsaplan/pi-raincatcher",
  "version": "0.1.0",
  "description": "Pi extension that captures durable facts from agent activity into markdown knowledge files.",
  "type": "module",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zsaplan/pi-extensions.git",
    "directory": "raincatcher"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "raincatcher",
    "knowledge-base"
  ],
  "files": [
    "src",
    "DESIGN.md",
    "README.md",
    "package.json"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "^0.70.0",
    "@mariozechner/pi-coding-agent": "^0.70.0"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
