    "verify": "npm run typecheck && npm run test"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "gts": "^7.0.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@zsaplan/rain-core": "file:../rain-core"
  }
