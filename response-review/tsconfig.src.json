{
  "extends": "../node_modules/gts/tsconfig-google.json",
  "compilerOptions": {
    "rootDir": ".",
    "noEmit": true,
    "allowJs": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "lib": ["ES2022"],
    "types": ["node"],
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.ts",
    "scripts/**/*.d.ts",
    "scripts/**/*.mjs"
  ],
  "exclude": [
    "web/**",
    "tmp/**"
  ]
}
